# Copy to .env.local — never commit .env.local
#
# Server-side API keys (Vercel project env + local dev via Vite proxy to /api/*)
ANTHROPIC_API_KEY=
PHOTOROOM_API_KEY=
#
# Optional legacy names for local migration (prefer ANTHROPIC_API_KEY / PHOTOROOM_API_KEY)
# VITE_ANTHROPIC_API_KEY=
# VITE_PHOTOROOM_API_KEY=
#
# Supabase (public anon key is safe in the client)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=
#
# Passkeys / Face ID (Vercel serverless only — never expose service role to the client)
SUPABASE_SERVICE_ROLE_KEY=
PASSKEY_RP_ID=app.allbyrent.com
PASSKEY_ORIGIN=https://app.allbyrent.com
# Optional: comma-separated extra origins (e.g. preview URLs)
# PASSKEY_ORIGINS=https://your-preview.vercel.app
# Optional: dedicated HMAC secret for WebAuthn challenges (else uses service role key)
# PASSKEY_SECRET=
