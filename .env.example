# Copy to .env.local — never commit .env.local
#
# Server-side API keys (Vercel project env + local dev via Vite proxy to /api/*)
ANTHROPIC_API_KEY=
PHOTOROOM_API_KEY=
#
# Optional legacy names for local migration (prefer ANTHROPIC_API_KEY / PHOTOROOM_API_KEY)
# VITE_ANTHROPIC_API_KEY=
# VITE_PHOTOROOM_API_KEY=
#
# Supabase (public anon key is safe in the client)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=
#
# Passkeys / Face ID (Vercel serverless only — never expose service role to the client)
SUPABASE_SERVICE_ROLE_KEY=
PASSKEY_RP_ID=app.evorios.com
PASSKEY_ORIGIN=https://app.evorios.com
# Optional: override app origin for Stripe return URLs (defaults to PASSKEY_ORIGIN)
# APP_ORIGIN=https://app.evorios.com
# Optional: comma-separated extra origins (e.g. preview URLs)
# PASSKEY_ORIGINS=https://your-preview.vercel.app
# Optional: dedicated HMAC secret for WebAuthn challenges (else uses service role key)
# PASSKEY_SECRET=
#
# Stripe — client publishable key + server secrets
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
#
# Web push (generate with web-push or similar)
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
